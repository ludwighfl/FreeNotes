/* ============================================================
   TOOLBAR (LIGHT)
   ============================================================ */

#toolbarWidget {
    background-color: #f5f5f5;
}

/* Tool Buttons */
QToolButton {
    background-color: transparent;
    border: none;
    border-radius: 6px;
    color: #555555;
    padding: 4px;
}

QToolButton:hover {
    background-color: #e0e0e0;
}

QToolButton:checked {
    background-color: #3B7BF5;
    color: #ffffff;
}

QToolButton:disabled {
    color: #b0b0b0;
}

/* ── Color Chip Buttons ── */
#colorChip {
    border: 2px solid transparent;
    border-radius: 14px;
    padding: 0px;
    background-color: transparent;
}

#colorChip:hover {
    border-color: rgba(0, 0, 0, 0.25);
}

#colorChip:checked {
    border: 2px solid #333333;
    background-color: transparent;
}

/* ── Pen Width Buttons ── */
#widthBtn {
    border-radius: 4px;
    background-color: transparent;
    border: none;
}

#widthBtn:hover {
    background-color: #e0e0e0;
}

#widthBtn:checked {
    background-color: #d8d8d8;
}

/* ── Add Color Button ── */
#addColorBtn {
    background-color: #e8e8e8;
    border: 2px dashed #b0b0b0;
    border-radius: 14px;
    color: #888888;
}

#addColorBtn:hover {
    border-color: #888888;
}

/* Toolbar separator */
#toolbarSeparator {
    color: #d0d0d0;
    margin: 0 8px;
}

/* ============================================================
   ERASER MODE TOGGLE
   ============================================================ */

#eraserModeBtn {
    border-radius: 4px;
    background: #e8e8e8;
    border: 1px solid #d0d0d0;
    color: #888888;
    padding: 2px 6px;
    font-size: 11px;
    font-weight: bold;
}

#eraserModeBtn:checked {
    background: #3B7BF5;
    border-color: #3B7BF5;
    color: #ffffff;
}

#eraserModeBtn:hover:!checked {
    background: #d8d8d8;
    color: #555555;
}

/* ── Undo/Redo Buttons ── */
#undoBtn, #redoBtn {
    background: transparent;
    border: 1px solid #d0d0d0;
    border-radius: 6px;
    padding: 6px;
}

#undoBtn:enabled, #redoBtn:enabled {
    border-color: #b0b0b0;
}

#undoBtn:enabled:hover, #redoBtn:enabled:hover {
    background: #e0e0e0;
    border-color: #999999;
}

#undoBtn:enabled:pressed, #redoBtn:enabled:pressed {
    background: #d0d0d0;
    border-color: #b0b0b0;
}

#undoBtn:disabled, #redoBtn:disabled {
    border-color: #e0e0e0;
    opacity: 0.4;
}

/* ── Font Controls (Text Tool in Toolbar) ── */
#fontSelector {
    background: #ffffff;
    border: 1px solid #d0d0d0;
    border-radius: 4px;
    color: #333333;
    padding: 2px 6px;
    font-size: 12px;
}
#fontSelector:hover {
    border-color: #b0b0b0;
}
#fontSelector QAbstractItemView {
    background: #ffffff;
    border: 1px solid #d0d0d0;
    color: #333333;
    selection-background-color: #3B7BF5;
}

#fontSizeSpin {
    background: #ffffff;
    border: 1px solid #d0d0d0;
    border-radius: 4px;
    color: #333333;
    padding: 2px 4px;
    font-size: 12px;
}
#fontSizeSpin:hover {
    border-color: #b0b0b0;
}
#fontSizeSpin::up-button, #fontSizeSpin::down-button {
    width: 14px;
    background: #e0e0e0;
    border-radius: 2px;
}

#boldBtn, #italicBtn {
    background: transparent;
    border: 1px solid transparent;
    border-radius: 4px;
    color: #888888;
    font-size: 13px;
    padding: 2px 6px;
    min-width: 24px;
}
#boldBtn:checked, #italicBtn:checked {
    background: #e0e0e0;
    border-color: #3B7BF5;
    color: #1a1a1a;
}
#boldBtn:hover:!checked, #italicBtn:hover:!checked {
    background: #e8e8e8;
    color: #333333;
}

/* ── Shape Tool Dropdown ── */
QToolButton#shapeToolBtn {
    background-color: transparent;
    border: none;
    border-radius: 6px;
    color: #555555;
    padding: 4px;
}

QToolButton#shapeToolBtn:hover {
    background-color: #e0e0e0;
}

QToolButton#shapeToolBtn:checked {
    background-color: #3B7BF5;
    color: #ffffff;
}

QToolButton#shapeToolBtn::menu-button {
    width: 12px;
    border-left: 1px solid #d0d0d0;
    background: transparent;
    border-radius: 0 4px 4px 0;
}

QToolButton#shapeToolBtn::menu-arrow {
    image: none;
    width: 0;
}

QMenu#shapeMenu {
    background: #ffffff;
    border: 1px solid #d0d0d0;
    border-radius: 6px;
    padding: 4px;
    color: #333333;
}

QMenu#shapeMenu::item {
    padding: 6px 12px;
    border-radius: 4px;
}

QMenu#shapeMenu::item:selected {
    background: #3B7BF5;
    color: #ffffff;
}

/* ============================================================
   THREE-DOT MENU
   ============================================================ */

QToolButton#threeDotBtn {
    background: transparent;
    border: 1px solid #d0d0d0;
    border-radius: 6px;
    color: #555555;
    font-size: 18px;
    font-weight: bold;
    letter-spacing: 2px;
}
QToolButton#threeDotBtn:hover {
    background: #e0e0e0;
    border-color: #b0b0b0;
}
QToolButton#threeDotBtn:pressed {
    background: #d0d0d0;
}
QToolButton#threeDotBtn::menu-indicator {
    width: 0;
    height: 0;
}

QMenu#threeDotMenu {
    background: #ffffff;
    border: 1px solid #d0d0d0;
    border-radius: 8px;
    padding: 4px;
    color: #333333;
    font-size: 13px;
}
QMenu#threeDotMenu::item {
    padding: 8px 20px;
    border-radius: 4px;
}
QMenu#threeDotMenu::item:selected {
    background: #3B7BF5;
    color: #ffffff;
}
QMenu#threeDotMenu::item:disabled {
    color: #b0b0b0;
}
QMenu#threeDotMenu::separator {
    height: 1px;
    background: #d0d0d0;
    margin: 4px 8px;
}

/* Page Context Menu */
QMenu#pageContextMenu {
    background: #ffffff;
    border: 1px solid #d0d0d0;
    border-radius: 8px;
    padding: 4px;
    color: #333333;
    font-size: 13px;
}
QMenu#pageContextMenu::item {
    padding: 8px 16px;
    border-radius: 4px;
}
QMenu#pageContextMenu::item:selected {
    background: #3B7BF5;
    color: #ffffff;
}
QMenu#pageContextMenu::item:disabled {
    color: #b0b0b0;
}
QMenu#pageContextMenu::separator {
    height: 1px;
    background: #d0d0d0;
    margin: 4px 8px;
}
